<% layout("layout/boilerplate.ejs") %>

<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<div class="container-fluid">
  <div class="row">

    <!-- SIDEBAR -->
 <button class="btn brger" data-bs-toggle="offcanvas" data-bs-target="#offcanvasWithBothOptions" aria-controls="offcanvasWithBothOptions"><i class="fa-solid fa-bars sidebar-toggle"></i>

<div  id="sidebar"></button>

<div class="offcanvas offcanvas-start" data-bs-scroll="true" tabindex="-1" id="offcanvasWithBothOptions" aria-labelledby="offcanvasWithBothOptionsLabel">
  <div class="offcanvas-header">
    <h5 class="offcanvas-title" id="offcanvasWithBothOptionsLabel">Backdrop with scrolling</h5>
    <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
  </div>
  <div class="offcanvas-body">
      <h4 class="text-success fw-bold mb-4">Krishibandh</h4>

      <a href="/" class="sidebar-link">
        <i class="fa-solid fa-house"></i> Dashboard
      </a>

      <a href="/orders" class="sidebar-link">
        <i class="fa-solid fa-box"></i> My Orders
      </a>

      <!-- <a href="/weather" class="sidebar-link">
        <i class="fa-solid fa-cloud-sun"></i> Weather
      </a> -->

      <!-- <a href="#" class="sidebar-link">
        <i class="fa-solid fa-chart-line"></i> Market Rate
      </a> -->

      <hr>

      <% if (currUser) { %>
        <a href="/logout" class="btn btn-outline-danger w-100 mt-3">
          <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
      <% } %>
      </div>
    </div>
</div>
     

    <!-- MAIN CONTENT -->
    <div class="col-md-2 col-lg-9 p-4 main">

      <!-- USER HEADER -->
      <div class="card user-card mb-4">
        <h2>Welcome,<%=currUser.username%></h2>
        <p class="text-muted">
          Manage your orders, income, and weather insights here.
        </p>
       
      </div>

      <!-- STATS CARDS -->
      <div class="row g-4">

        <div class="col-md-4">
          <div class="stat-card">
            <div>
              <small>Total Orders</small>
              <h2>
            <!--h2> -->
            </div>
            <i class="fa-solid fa-cube"></i>
          </div>
        </div>

        <div class="col-md-4">
          <div class="stat-card">
            <div>
              <small>Completed Orders</small>
              <!-- <h2>h2> -->
            </div>
            <i class="fa-solid fa-clipboard-check"></i>
          </div>
        </div>

        <div class="col-md-4">
          <div class="stat-card">
            <div>
              <small>Total Income</small>
              <!-- <h2>₹h2> -->
            </div>
            <i class="fa-solid fa-indian-rupee-sign"></i>
          </div>
        </div>

      </div>

      <div class="card mt-5 p-4 shadow-sm">
  <h5 class="mb-4 text-success fw-bold">
    <i class="fa-solid fa-truck"></i> Coming Orders
  </h5>

  <% if (typeof allStorage !== "undefined" && allStorage.length > 0) { %>

    <div class="row g-3">
      <% for(let storage of allStorage ){ %>
   <a href="/Storage/Dashbord/<%= storage._id %>" class="order-link">
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body">

              <h6 class="fw-bold text-success">
                <i class="fa-solid fa-seedling"></i>
                <%= storage.cropName %>
              </h6>

              <p class="mb-2">
                <i class="fa-solid fa-phone text-primary"></i>
                <%= storage.phone %>
              </p>

            </div>
          </div>
        </div>

      <% } %>
    </div>

  <% } else { %>

    <div class="alert alert-warning text-center">
      No Coming Orders Found
    </div>

  <% } %>
</div>


    </div>
    </a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>  
<script>
  let btn = document.querySelector(".sidebar-toggle");
  let sidebar = document.getElementById("sidebar");

  btn.addEventListener("click", function() {
    sidebar.classList.toggle("active");
  });
</script>