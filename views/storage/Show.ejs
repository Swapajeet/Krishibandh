<% layout("layout/boilerplate.ejs") -%>
<div class="container mt-5">

  <div class="card shadow-lg p-4">

    <h2 class="text-success fw-bold">
      <%=storageData.cropName %>
    </h2>

    <!-- <p class="text-muted">Category: <%= storageData.category %></p> -->

    <p><strong>Count:</strong> <%= storageData.preserveCount %></p>

    <p><strong>Status:</strong> 
      <span class="badge bg-<%= storageData.status === 'deal' ? 'success' : 'warning' %>">
        <%= storageData.status %>
      </span>
    </p>

    <p><strong>Temperature:</strong> <%=storageData.temperature %> °C</p>

    <hr>

    <p><strong>Description:</strong></p>
    <p><%= storageData.description %></p>

    <p><strong>Instructions:</strong></p>
    <p><%= storageData.instructions %></p>

    <% if (storageData.cropImages && storageData.cropImages.url) { %>
      <img src="<%= storageData.cropImages.url %>" 
           class="img-fluid rounded mt-3" 
           style="max-height:300px;">
    <% } %>

    <hr>

    <p class="text-muted">
      Added by: <%= storageData.author?.username %>
    </p>

    <p class="text-muted">
      Created At: <%= storageData.createdAt.toDateString() %>
    </p>

     <% if (currUser && currUser.role === "storage") { %>
       <div>
          
<form
  action="/Storage/Dashbord/<%= storageData._id %>/status?_method=PUT"
  method="POST"
>
  <div class="mb-3">
    <label class="form-label fw-semibold">Update Status</label>

    <select name="status" class="form-select" required>
      <option value="pending"
        <%= storageData.status === "pending" ? "selected" : "" %>>
        Pending
      </option>
   
      <option value="Accepted"
        <%= storageData.status === "Accepted" ? "selected" : "" %>>
        Accepted
      </option>
        
      <% } %>
    </select>
     </div>

         <button class="btn btn-success btn-sm">
              <i class="fa-solid fa-rotate"></i> Update Status
        </button>

</form>
       </div>

  </div>
  
</div>