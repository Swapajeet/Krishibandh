<%- layout("layout/boilerplate.ejs") %>


<form
  action="/orders/<%= order._id %>/cotation/<%= cotation._id %>/status?_method=PUT"
  method="POST"
>

  <div class="mb-3">
    <label class="form-label fw-semibold">Update Status</label>

    <select name="status" class="form-select" required>
      <option value="pending"
        <%= cotation.status === "pending" ? "selected" : "" %>>
        Pending
      </option>
    <% if (currUser && currUser.role === "branch") { %>
      <option value="Accepted"
        <%= cotation.status === "Accepted" ? "selected" : "" %>>
        Accepted
      </option>
        
       <option value="visting"
        <%= cotation.status === "visting" ? "selected" : "" %>>
        visting
      </option>
      <% } %>
    </select>
  </div>

  <button class="btn btn-success btn-sm">
    <i class="fa-solid fa-rotate"></i> Update Status
  </button>

</form>
