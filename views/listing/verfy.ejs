<%- layout("layout/boilerplate.ejs") %>

<div class="container mt-5">

  <div class="text-center mb-4">
    <h2 class="fw-bold" style="color:#2c3e50;">Visiting Orders</h2>
    <p class="text-muted">All quotation details</p>
  </div>

  <% for (let order of allorders) { %>

    <% if(order.cotation && order.cotation.length > 0) { %>

      <% for (let quote of order.cotation) { %>

        <div class="card border-0 shadow-lg rounded-4 mb-4 hover-card"
             style="background: linear-gradient(135deg, #ffffff, #f8fbff);">

          <div class="card-body p-4">

            <div class="row align-items-center">

              <!-- Owner Info -->
              <div class="col-md-4">
                <h5 class="fw-bold text-dark mb-2">
                  <i class="bi bi-person-circle text-primary me-2"></i>
                  <%= order.owner ? order.owner.username : "No Owner" %>
                </h5>

                <span class="badge bg-light text-dark px-3 py-2 rounded-pill">
                  🌾 <%= order.cropName %>
                </span>
              </div>

              <!-- Quotation Info -->
              <div class="col-md-5 mt-3 mt-md-0">
                <p class="mb-2">
                  <strong>Amount:</strong> 
                  <span class="text-success fw-bold fs-5">
                    ₹ <%= quote.price %>
                  </span>
                </p>

                <p class="mb-2">
                  <strong>Quotation By:</strong>
                  <%= quote.auther ? quote.auther.username : "No User" %>
                </p>

                <p class="mb-0">
                  <strong>Status:</strong>

                  <% if(quote.status === "deal") { %>
                    <span class="badge bg-success px-3 py-2 rounded-pill">
                      ✔ Deal
                    </span>
                  <% } else  if (quote.status === "pending"){%>
                    <span class="badge bg-warning text-dark px-3 py-2 rounded-pill">
                      ⏳ Pending
                    </span>
                    <% } else{ %>
                       <span class="badge bg-success px-3 py-2 rounded-pill">
                      ✔ completed
                    </span>
                    <% } %>
                </p>
              </div>

              <!-- Action -->
              <div class="col-md-3 text-md-end mt-3 mt-md-0">
                <a href="/orders/<%= order._id %>/cotation/<%= quote._id %>/update"
                   class="btn btn-outline-primary rounded-pill px-4">
                   Update
                </a>
              </div>

            </div>

          </div>
        </div>

      <% } %>

    <% } %>

  <% } %>

</div>

<style>
.hover-card {
  transition: all 0.3s ease;
}
.hover-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 12px 25px rgba(0,0,0,0.1);
}
</style>