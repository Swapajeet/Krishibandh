<div class="point"><h3><i class="fa-solid fa-network-wired"></i> Strong and Transparent Supply Chain</h3><p>Better business trust.</p></div>
<div class="point"><h3><i class="fa-solid fa-mobile-screen-button"></i> Easy-to-Use Farmer Friendly App</h3><p>Simple mobile interface.</p></div>
<div class="point"><h3><i class="fa-solid fa-headset"></i> 24/7 Customer Support</h3><p>Support anytime.</p></div>
</div>
</div>

<!-- COMPANY LOGOS -->
<div class="company-slider-section">
  <h2>Our Trusted Companies</h2>
  <div class="logo-slider">
    <div class="logo-track">
      <div class="logo-card"><p>AgroStar</p></div>
      <div class="logo-card"><p>ITC Foods</p></div>
      <div class="logo-card"><p>PepsiCo India</p></div>
      <div class="logo-card"><p>AgroStar</p></div>
      <div class="logo-card"><p>ITC Foods</p></div>
      <div class="logo-card"><p>PepsiCo India</p></div>
    </div>
  </div>
</div>

<!-- GROWTH CHART -->
<div class="chart-section">
  <h2>📊 Farmer Growth Overview</h2>
  <div class="chart-box">
    <canvas id="growthChart" height="120"></canvas>
  </div>
</div>

<!-- HOW IT WORKS -->
<div class="section">
<h2>How It Works</h2>
<div class="cards">
<div class="card"><h3>🌾 Upload Products</h3><p>Farmers upload crops & fruits.</p></div>
<div class="card"><h3>💰 Get Best Price</h3><p>Companies offer fair pricing.</p></div>
<div class="card"><h3>🚚 Direct Supply</h3><p>Safe and transparent delivery.</p></div>
</div>
</div>

<!-- FEEDBACK -->
<div class="feedback-section">
<h2>Give Feedback</h2>
<div class="feedback-form">
<input type="text" placeholder="Farmer Name" required>
<textarea rows="4" placeholder="Write your feedback..." required></textarea>
<button type="submit">Submit Feedback</button>
</div>
</div>



<script>
// hero slider
let slides=document.querySelectorAll(".slide");
let index=0;
setInterval(()=>{
  slides[index].classList.remove("active");
  index=(index+1)%slides.length;
  slides[index].classList.add("active");
},3000);

// growth chart
const gctx=document.getElementById('growthChart');
new Chart(gctx,{
  type:'line',
  data:{
    labels:['Jan','Feb','Mar','Apr','May','Jun'],
    datasets:[{
      label:'Farmer Income Growth (₹)',
      data:[20000,25000,23000,28000,32000,37000],
      tension:0.4,
      fill:true
    }]
  },
  options:{responsive:true}
});
</script>

